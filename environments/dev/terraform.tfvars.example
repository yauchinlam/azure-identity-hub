# Copy to terraform.tfvars and adjust as needed.
# terraform.tfvars is gitignored.
#
# Set the target subscription before plan/apply (not stored in this repo):
#   az account set --subscription "<subscription-id>"
# or export ARM_SUBSCRIPTION_ID="<subscription-id>"

github_owner     = "<github-owner>"
github_repo_name = "azure-identity-hub"
environment      = "dev"
location         = "eastus"

# Shared tfstate reference: copy hub_settings.tfvars.json.example to hub_settings.tfvars.json
# Repo roster: edit github_repos.tfvars.json (committed) and push to main.

tags = {
  repository  = "azure-identity-hub"
  environment = "dev"
  managed_by  = "terraform"
}
